{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Maestro",
  "version": "0.1.0",
  "identifier": "com.lezhao.maestro",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Maestro",
        "label": "main",
        "width": 1280,
        "height": 820,
        "minWidth": 1080,
        "minHeight": 700
      },
      {
        "title": "Jiavis HUD",
        "label": "jiavis",
        "width": 600,
        "height": 400,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "center": true,
        "visible": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' tauri: asset:",
        "connect-src": "'self' ipc: http://ipc.localhost http://localhost:1420 ws://localhost:1421 http://127.0.0.1:1420 ws://127.0.0.1:1421",
        "img-src": "'self' asset: blob: data:",
        "style-src": "'self' 'unsafe-inline'",
        "font-src": "'self'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
